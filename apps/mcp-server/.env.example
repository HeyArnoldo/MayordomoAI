# ════════════════════════════════════════════════════════════════════
# @app/mcp-server — environment variables
# Copy to .env in this directory: cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# Port the MCP server listens on.
# Expose this port publicly (via ngrok, Coolify, etc.) for Azure AI Foundry.
PORT=3001

# Base URL of the MayordomoAI NestJS API (no trailing slash).
# In production this is the internal hostname of the API container.
MAYORDOMO_API_BASE_URL=http://localhost:3000

# Shared secret between the MCP server and the NestJS API.
# Must match AGENT_TOOL_INTERNAL_KEY in apps/api/.env.
# Generate: openssl rand -hex 32
AGENT_TOOL_INTERNAL_KEY=

# Bearer token that Azure AI Foundry (or any MCP client) must send as:
#   Authorization: Bearer <MCP_AUTH_TOKEN>
# Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=
