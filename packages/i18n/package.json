{
  "name": "@app/i18n",
  "version": "0.1.0",
  "private": true,
  "description": "Recursos de traducción es/en y helpers de formato — una sola fuente para web y API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@app/contracts": "workspace:*"
  },
  "devDependencies": {
    "@app/tsconfig": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3"
  }
}
